# PostgreSQL
DATABASE_URL=ecto://postgres:postgres@localhost/uw_billing_prod

# Phoenix
SECRET_KEY_BASE=your_64_char_secret_key_base_here
PHX_HOST=localhost
PHX_SERVER=true
PORT=4000

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=uw_billing
CLICKHOUSE_USER=default
CLICKHOUSE_PASS=
CLICKHOUSE_POOL_SIZE=5

# Stripe (env fallback — DB-stored credentials take priority when saved via SetupPage)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...

# Unusual Whales API (optional — Congress poller falls back to EDGAR public endpoint)
UW_API_KEY=

# Ecto connection options
POOL_SIZE=10
ECTO_IPV6=false
