# ── Stripe (required) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Phoenix / Postgres (required) ───────────────────────────────────────────
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=
POSTGRES_PASSWORD=postgres
POSTGRES_DB=uw_billing

# Domain for absolute URLs (used by Phoenix endpoint config)
PHX_HOST=localhost

# Host port to bind (container always listens on 4200 internally)
APP_PORT=4200

# ── Optional ────────────────────────────────────────────────────────────────
# Unusual Whales API key (Congress poller falls back to EDGAR if not set)
UW_API_KEY=

# Stripe price IDs (auto-provisioned on first boot if not set)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PREMIUM_MONTHLY=

# ClickHouse overrides (already set by docker-compose; only needed outside Docker)
# CLICKHOUSE_HOST=localhost
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_DB=uw_billing
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASS=
# CLICKHOUSE_POOL_SIZE=5
