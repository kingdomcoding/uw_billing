# ── Required everywhere ───────────────────────────────────────────────────────

# Stripe: get from dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# Run first, paste the whsec_... output here:
#   stripe listen --forward-to localhost:4000/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Required for production (docker-compose.prod.yml) ─────────────────────────

# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# Postgres password for the prod container
POSTGRES_PASSWORD=changeme

# Your domain (used in absolute URLs and TLS cert)
PHX_HOST=yourdomain.com

# ── Optional ──────────────────────────────────────────────────────────────────

# Unusual Whales API key (Congress poller falls back to EDGAR if not set)
UW_API_KEY=

# Stripe price IDs (seeds fall back to dev placeholders if not set)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PREMIUM_MONTHLY=

# ClickHouse overrides (already set by docker-compose; only needed for custom deployments)
# CLICKHOUSE_HOST=localhost
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_DB=uw_billing
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASS=
# CLICKHOUSE_POOL_SIZE=5
