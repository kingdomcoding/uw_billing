#!/usr/bin/env bash
# Full demo reset: Postgres + ClickHouse, then purge any webhook-replayed rows.
set -e
cd "$(dirname "$0")/.."

echo "==> Resetting Postgres..."
DB_URL="postgresql://postgres:postgres@localhost:5432"
psql "$DB_URL/postgres" \
  -c "DROP DATABASE IF EXISTS uw_billing_dev WITH (FORCE);" \
  -c "CREATE DATABASE uw_billing_dev;"
mix ash.setup
mix run priv/repo/seeds.exs

echo "==> Resetting ClickHouse..."
docker exec uw_billing-clickhouse-1 clickhouse-client \
  --query "DROP DATABASE IF EXISTS uw_billing_dev"
docker exec uw_billing-clickhouse-1 clickhouse-client \
  --query "CREATE DATABASE uw_billing_dev"
docker exec -i uw_billing-clickhouse-1 clickhouse-client \
  --database uw_billing_dev < priv/clickhouse/init.sql

echo "==> Done. Run: mix phx.server"
