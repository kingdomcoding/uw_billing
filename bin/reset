#!/usr/bin/env bash
# Full demo reset: Postgres + ClickHouse, then purge any webhook-replayed rows.
set -e
cd "$(dirname "$0")/.."

: "${STRIPE_SECRET_KEY:?STRIPE_SECRET_KEY is required. Run: cp .env.example .env, fill in your credentials, then: source .env}"
: "${STRIPE_WEBHOOK_SECRET:?STRIPE_WEBHOOK_SECRET is required. Run: stripe listen --forward-to localhost:4000/webhooks/stripe, then set the whsec_... in .env and: source .env}"

echo "==> Resetting Postgres..."
DB_URL="postgresql://postgres:postgres@localhost:5432"
psql "$DB_URL/postgres" \
  -c "DROP DATABASE IF EXISTS uw_billing_dev WITH (FORCE);" \
  -c "CREATE DATABASE uw_billing_dev;"
mix ash.setup

echo "==> Resetting ClickHouse..."
docker exec uw_billing-clickhouse-1 clickhouse-client \
  --query "DROP DATABASE IF EXISTS uw_billing"
docker exec uw_billing-clickhouse-1 clickhouse-client \
  --query "CREATE DATABASE uw_billing"
docker exec -i uw_billing-clickhouse-1 clickhouse-client \
  < priv/clickhouse/init.sql

mix run priv/repo/seeds.exs
mix run priv/scripts/setup_stripe.exs

echo "==> Done. Run: mix phx.server"
